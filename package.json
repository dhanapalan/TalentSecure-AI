{
  "name": "talentsecure-ai",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered campus recruitment platform with smart segmentation and secure proctored assessments",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:lendershub": "cd frontend && npm run dev",
    "dev:ai": "cd ai-engine && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd server && npm run build",
    "build:client": "cd client && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "lint": "concurrently \"cd server && npm run lint\" \"cd client && npm run lint\"",
    "test": "concurrently \"cd server && npm test\" \"cd client && npm test\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "overrides": {
    "ioredis": "5.10.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
