# ==============================================================================
# TalentSecure AI — Environment Configuration
# ==============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5050
CLIENT_URL=http://localhost:5173
ADMIN_CLIENT_URL=http://admin.localhost:5173
COLLEGE_CLIENT_URL=http://campus.localhost:5173
STUDENT_CLIENT_URL=http://exam.localhost:5173
# Optional comma-separated override for all allowed frontend origins:
# CLIENT_URLS=http://localhost:5173,http://admin.localhost:5173,http://campus.localhost:5173,http://exam.localhost:5173
AI_ENGINE_URL=http://localhost:8000
DISABLE_RATE_LIMIT=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5433
PG_USER=talentsecure
PG_PASSWORD=secret
PG_DATABASE=talentsecure
DATABASE_URL=postgresql://talentsecure:secret@localhost:5433/talentsecure?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
# When set, the redis container starts with --requirepass and the API sends this
# as a client option. Leave blank to run redis without authentication (dev only).
REDIS_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# ── OAuth 2.0 — Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── OAuth 2.0 — Microsoft ────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/microsoft/callback

# ── AWS S3 / MinIO ───────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=talentsecure-uploads
S3_REGION=us-east-1

# ── Proctoring ────────────────────────────────────────────────────────────────
PROCTORING_FACE_MATCH_THRESHOLD=0.85
PROCTORING_SNAPSHOT_INTERVAL_MS=5000
PROCTORING_MAX_VIOLATIONS=3
TURN_SERVER_URL=turn:your-turn-server:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# ── AI Engine ─────────────────────────────────────────────────────────────────
ML_MODEL_PATH=./ai-engine/models
SEGMENTATION_MIN_CLUSTER_SIZE=10
MATCHING_SCORE_THRESHOLD=0.70

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
EMAIL_FROM="TalentSecure AI <noreply@talentsecure.ai>"

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Vapi.ai (Voice AI Mock Interviews) ───────────────────────────────────────
# Get your keys at: https://dashboard.vapi.ai → Account → API Keys
# VAPI_API_KEY    → private server key  (never expose to browser)
# VAPI_PUBLIC_KEY → public key          (sent to client to start calls)
# VAPI_WEBHOOK_SECRET → set in Vapi dashboard → Webhooks → Secret
VAPI_API_KEY=your-vapi-private-key
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ==============================================================================
# Docker Compose — required by docker-compose.yml
# ==============================================================================
# These are consumed by the compose file itself, not by application code. The
# stack will start without them and silently misbehave, so set them explicitly.

# ── Compose project name ──────────────────────────────────────────────────────
# Docker derives volume names from the project name, which defaults to the
# directory name. Renaming or re-cloning the deploy directory therefore
# repoints every volume at a NEW EMPTY ONE and the stack comes up healthy with
# no data. Pin it and never change it for an existing deployment.
COMPOSE_PROJECT_NAME=talentsecure-ai

# ── Postgres container ────────────────────────────────────────────────────────
# Only applied when initialising an EMPTY volume. On an existing volume these
# are ignored, so changing POSTGRES_PASSWORD here does not rotate the password —
# use ALTER ROLE and update DATABASE_URL to match.
POSTGRES_PASSWORD=secret

# ── MinIO container ───────────────────────────────────────────────────────────
# MUST match S3_ACCESS_KEY / S3_SECRET_KEY above, or the API logs
# "S3 unavailable" and every upload is disabled. Password must be >= 8 chars.
MINIO_ROOT_USER=gradlogic
MINIO_ROOT_PASSWORD=change-me-at-least-8-chars

# ── Published host ports ──────────────────────────────────────────────────────
# Accepts an interface prefix. In production keep these on loopback so only the
# reverse proxy is internet-facing: TS_POSTGRES_PORT=127.0.0.1:5433
TS_POSTGRES_PORT=5433
TS_REDIS_PORT=6380
