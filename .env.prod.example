# ==============================================================================
# TalentSecure AI — PRODUCTION Environment
# Copy to .env on your VPS:  cp .env.prod.example .env
# Lock it down:              chmod 600 .env
# Generate secrets:          openssl rand -base64 64
# ==============================================================================

NODE_ENV=production
PORT=5050

# ── Frontend URLs (all origins allowed for CORS) ──────────────────────────────
CLIENT_URL=https://atherasys.com
ADMIN_CLIENT_URL=https://admin.atherasys.com
COLLEGE_CLIENT_URL=https://campus.atherasys.com
STUDENT_CLIENT_URL=https://exam.atherasys.com
CLIENT_URLS=https://atherasys.com,https://www.atherasys.com,https://admin.atherasys.com,https://campus.atherasys.com,https://exam.atherasys.com

AI_ENGINE_URL=http://ai-engine:8000
DISABLE_RATE_LIMIT=false

# ── Database → Supabase ───────────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → Database
# Use "Session mode" connection string (port 5432) for long-lived server connections
PG_HOST=db.tmutpbunrcdtvdkqhvcn.supabase.co
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=YOUR_SUPABASE_DB_PASSWORD
PG_DATABASE=postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.tmutpbunrcdtvdkqhvcn.supabase.co:5432/postgres

# ── Redis → Upstash ───────────────────────────────────────────────────────────
# Get from: upstash.com → Database → Details → Redis URL
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST:6379

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_64
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME_run_openssl_rand_base64_64
REFRESH_TOKEN_EXPIRES_IN=30d

# ── OAuth 2.0 — Microsoft (Azure AD / MSAL) ──────────────────────────────────
# In Azure AD App → Authentication → Redirect URIs add:
#   https://atherasys.com/auth/callback
MSAL_CLIENT_ID=your-azure-app-client-id
MSAL_CLIENT_SECRET=your-azure-app-client-secret
MSAL_TENANT_ID=common
MSAL_REDIRECT_URI=https://atherasys.com/auth/callback

# ── OAuth 2.0 — Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.atherasys.com/api/auth/google/callback

# ── Storage → Supabase Storage ────────────────────────────────────────────────
# Get from: supabase.com → Project → Settings → API
# Supabase Storage is S3-compatible — use these values:
S3_ENDPOINT=https://tmutpbunrcdtvdkqhvcn.supabase.co/storage/v1/s3
S3_ACCESS_KEY=YOUR_SUPABASE_ANON_KEY
S3_SECRET_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
S3_BUCKET=talentsecure-uploads
S3_REGION=us-east-1

# ── AI Engine ─────────────────────────────────────────────────────────────────
AI_ENGINE_API_KEY=CHANGE_ME_run_openssl_rand_hex_32
ML_MODEL_PATH=./ai-engine/models
SEGMENTATION_MIN_CLUSTER_SIZE=10
MATCHING_SCORE_THRESHOLD=0.70

# ── Proctoring ────────────────────────────────────────────────────────────────
PROCTORING_FACE_MATCH_THRESHOLD=0.85
PROCTORING_SNAPSHOT_INTERVAL_MS=5000
PROCTORING_MAX_VIOLATIONS=3
TURN_SERVER_URL=turn:your-turn-server:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="TalentSecure AI <noreply@atherasys.com>"

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key...
OPENAI_MODEL=gpt-4o

# ── Judge0 (code execution) ──────────────────────────────────────────────────
# Judge0 uses its own local postgres+redis containers for sandboxing
JUDGE0_API_URL=http://judge0:2358
JUDGE0_REDIS_URL=redis://judge0-redis:6379
JUDGE0_PG_HOST=judge0-postgres
JUDGE0_PG_USER=judge0
JUDGE0_PG_PASSWORD=CHANGE_ME_run_openssl_rand_hex_32
JUDGE0_PG_DB=judge0_db
