# ==============================================================================
# TalentSecure AI (GradLogic) — PRODUCTION Environment
# Copy to .env on your VPS:  cp .env.prod.example .env
# Lock it down:              chmod 600 .env
# ==============================================================================

NODE_ENV=production
PORT=5050

# ── Frontend URLs ──────────────────────────────────────────────────────────────
CLIENT_URL=https://gradlogic.atherasys.com
ADMIN_CLIENT_URL=https://admin.gradlogic.atherasys.com
COLLEGE_CLIENT_URL=https://campus.gradlogic.atherasys.com
STUDENT_CLIENT_URL=https://exam.gradlogic.atherasys.com
CLIENT_URLS=https://gradlogic.atherasys.com,https://www.gradlogic.atherasys.com,https://admin.gradlogic.atherasys.com,https://campus.gradlogic.atherasys.com,https://exam.gradlogic.atherasys.com

AI_ENGINE_URL=http://ai-engine:8000
DISABLE_RATE_LIMIT=false
# Optional override (default 2000 in production, 100 in dev)
# RATE_LIMIT_MAX=2000

# ── Database → local PostgreSQL (runs in Docker on this VPS) ─────────────────
PG_HOST=postgres
PG_PORT=5432
PG_USER=talentsecure
PG_PASSWORD=changeme_strong_password
PG_DATABASE=talentsecure
DATABASE_URL=postgresql://talentsecure:changeme_strong_password@postgres:5432/talentsecure

# ── Redis → local Redis (runs in Docker on this VPS) ─────────────────────────
# Set a password in production. It must appear BOTH here (so the redis container
# enables auth) and inside REDIS_URL (so the API authenticates).
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_URL=redis://:change-me-strong-redis-password@redis:6379

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED — the server refuses to start in production without a real JWT_SECRET.
# Generate each with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME__openssl_rand_-base64_48
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=CHANGE_ME__openssl_rand_-base64_48
REFRESH_TOKEN_EXPIRES_IN=30d

# ── OAuth 2.0 — Microsoft (Azure AD / MSAL) ──────────────────────────────────
MSAL_CLIENT_ID=your-azure-app-client-id
MSAL_CLIENT_SECRET=your-azure-app-client-secret
MSAL_TENANT_ID=common
MSAL_REDIRECT_URI=https://gradlogic.atherasys.com/auth/callback

# ── OAuth 2.0 — Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.gradlogic.atherasys.com/api/auth/google/callback

# ── Storage → Supabase Storage ────────────────────────────────────────────────
S3_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
# Supabase → Project Settings → API. NEVER commit the service_role key.
S3_ACCESS_KEY=your-supabase-anon-key
S3_SECRET_KEY=your-supabase-service-role-key
S3_BUCKET=talentsecure-uploads
S3_REGION=ap-south-1

# ── AI Engine ─────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32  (must match the AI engine's own .env)
AI_ENGINE_API_KEY=CHANGE_ME__openssl_rand_-hex_32
ML_MODEL_PATH=./ai-engine/models
SEGMENTATION_MIN_CLUSTER_SIZE=10
MATCHING_SCORE_THRESHOLD=0.70

# ── Proctoring ────────────────────────────────────────────────────────────────
PROCTORING_FACE_MATCH_THRESHOLD=0.85
PROCTORING_SNAPSHOT_INTERVAL_MS=5000
PROCTORING_MAX_VIOLATIONS=3
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="GradLogic <noreply@atherasys.com>"

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
# Used by resume extraction, AI coach/feedback, course builder, voice interview
# summaries. Without it those features return "ANTHROPIC_API_KEY is not
# configured". Can also be set at runtime from the superadmin AI Services page
# (stored AES-encrypted in the DB and applied without a restart).
ANTHROPIC_API_KEY=sk-ant-...your-key...

# ── Groq (drive question generation; falls back to mock generator if unset,
# or after repeated failures). Can also be set at runtime from the superadmin
# AI Services page (stored AES-encrypted in the DB and applied without a
# restart).
GROQ_API_KEY=gsk_...your-key...
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI — legacy, no code path calls this anymore ──────────────────────────
OPENAI_API_KEY=sk-...your-key...
OPENAI_MODEL=gpt-4o

# ── Vapi (voice interviews) ──────────────────────────────────────────────────
VAPI_API_KEY=

# ── Judge0 (code execution sandbox — runs locally in Docker) ─────────────────
JUDGE0_API_URL=http://judge0:2358
JUDGE0_REDIS_URL=redis://judge0-redis:6379
JUDGE0_PG_HOST=judge0-postgres
JUDGE0_PG_USER=judge0
JUDGE0_PG_PASSWORD=CHANGE_ME__openssl_rand_-hex_24
JUDGE0_PG_DB=judge0_db
