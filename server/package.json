{
  "name": "talentsecure-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TalentSecure AI — Backend API Server",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:legacy": "tsx watch src/index.ts",
    "build": "tsc --pretty false || node -e \"process.exit(require('fs').existsSync('dist/index.js')?0:1)\"",
    "build:check": "tsc --pretty false --noEmit",
    "start": "node dist/main.js",
    "start:legacy": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "tsc --noEmit",
    "test:unit": "tsx --test src/__tests__/studentAssessmentWorkspace.rules.test.ts src/__tests__/collegeMasterFields.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@aws-sdk/client-s3": "^3.730.0",
    "@azure/msal-node": "^5.0.5",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "prisma": "6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.22",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.19.0",
    "swagger-autogen": "^2.23.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
