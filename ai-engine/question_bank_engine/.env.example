# AI Question Bank Engine Configuration
# Copy this to .env and fill in your values

# ── Environment ──────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── LLM Configuration ────────────────────────────────────────────────────

# LLM Provider: groq | openai | ollama | anthropic
LLM_PROVIDER=groq

# Groq (Recommended - Fast & Cheap)
# Get API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=mixtral-8x7b-32768
# Alternative models: llama2-70b-4096, llama-2-13b-chat

# OpenAI (Fallback)
OPENAI_API_KEY=sk_your_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (Fully Local - No API key needed)
# First: Install Ollama from https://ollama.ai
# Then: ollama pull llama2 (or mixtral, neural-chat, etc.)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Anthropic Claude
ANTHROPIC_API_KEY=sk_ant_your_api_key_here
ANTHROPIC_MODEL=claude-opus

# ── Embedding Configuration ──────────────────────────────────────────────

# Embedding Model (HuggingFace - all run locally)
# Options:
#   sentence-transformers/all-MiniLM-L6-v2          (Fast, 384-dim, ~70MB)
#   sentence-transformers/all-mpnet-base-v2         (Better, 768-dim, ~430MB)
#   sentence-transformers/paraphrase-multilingual-mpnet-base-v2  (Multi-lang)
#   sentence-transformers/all-roberta-large-v1      (Best quality, 1024-dim, ~700MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE=./data/embeddings
EMBEDDING_DEVICE=cpu
# EMBEDDING_DEVICE=cuda  # For GPU acceleration (if CUDA available)

# ── Vector Store Configuration ───────────────────────────────────────────

# ChromaDB Settings
VECTOR_STORE_BACKEND=chroma
VECTOR_STORE_COLLECTION_NAME=knowledge_base
VECTOR_STORE_DISTANCE_METRIC=cosine
# Options: cosine, l2, ip (inner product)

# Chunking
VECTOR_STORE_CHUNK_SIZE=1024
VECTOR_STORE_CHUNK_OVERLAP=256
VECTOR_STORE_TOP_K=5
VECTOR_STORE_SIMILARITY_THRESHOLD=0.5

# ── Document Processing ─────────────────────────────────────────────────

DOCUMENT_MAX_FILE_SIZE_MB=50
DOCUMENT_ENABLE_OCR=false
DOCUMENT_OCR_LANGUAGE=eng

# ── API Configuration ───────────────────────────────────────────────────

API_HOST=0.0.0.0
API_PORT=8001
API_RELOAD=true
QUESTION_ENGINE_API_KEY=dev-key-question-engine
CORS_ORIGINS=http://localhost:5173,http://localhost:5000,http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────

LOG_FORMAT=json
# Options: json, text

# ── Optional: Knowledge Base Seeding ─────────────────────────────────────

# Set to true to automatically seed knowledge base on startup
# Requires sample documents in ./data/documents/
AUTOLOAD_DOCUMENTS=false

# ── Redis Configuration (for job queue - future) ─────────────────────────

REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# ── Monitoring (future) ──────────────────────────────────────────────────

ENABLE_TELEMETRY=false
SENTRY_DSN=

# ── Notes ────────────────────────────────────────────────────────────────

# Quick Start:
# 1. Copy this file to .env
# 2. Fill in your LLM API keys (at least one provider)
# 3. Run: pip install -r requirements.txt
# 4. Run: python -m question_bank_engine.api
# 5. Visit: http://localhost:8001/docs

# For local-only (no API keys):
# 1. Install Ollama: https://ollama.ai
# 2. Set LLM_PROVIDER=ollama
# 3. Run: ollama pull llama2
# 4. Start: ollama serve (in another terminal)
# 5. Run the engine as above
